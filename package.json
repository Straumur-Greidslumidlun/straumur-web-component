{
  "name": "straumur-web-component",
  "version": "1.1.2-alpha.1",
  "license": "MIT",
  "homepage": "https://docs.straumur.is",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    "import": "./dist/index.mjs",
    "default": "./dist/index.js"
  },
  "description": "Embeddable payment checkout component for Straumur with support for cards, Apple Pay, Google Pay, 3D Secure, and stored payment methods",
  "keywords": [
    "straumur",
    "checkout",
    "payment",
    "payments",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Straumur-Greidslumidlun/straumur-web-component.git"
  },
  "bugs": {
    "url": "https://github.com/Straumur-Greidslumidlun/straumur-web-component/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@adyen/adyen-web": "6.25.0",
    "preact": "~10.28.2"
  },
  "devDependencies": {
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tslib": "^2.8.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
